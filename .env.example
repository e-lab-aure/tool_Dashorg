IMAP_HOST=ssl0.ovh.net
IMAP_PORT=993
IMAP_USER=ton.adresse@mondomaine.fr
IMAP_PASSWORD=xxx
IMAP_TLS=true

# Action appliquée sur chaque email après import dans Dashorg.
# Valeurs possibles :
#   read    — marque l'email comme lu (flag \Seen) — peut ne pas fonctionner sur certains serveurs
#   delete  — supprime définitivement l'email de la boîte
#   archive — déplace l'email dans le dossier IMAP_ARCHIVE_FOLDER
IMAP_PROCESSED_ACTION=delete

# Dossier de destination quand IMAP_PROCESSED_ACTION=archive
IMAP_ARCHIVE_FOLDER=Archive

NEXT_PUBLIC_APP_TITLE=Dashorg
