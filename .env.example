# ─── Configuration IMAP ──────────────────────────────────────────────────────
IMAP_HOST=ssl0.ovh.net
IMAP_PORT=993
IMAP_USER=ton.adresse@mondomaine.fr
IMAP_PASSWORD=xxx
IMAP_TLS=true

# Action appliquee sur chaque email apres import dans Dashorg.
# Valeurs possibles :
#   read    - marque l'email comme lu (flag \Seen)
#   delete  - supprime definitivement l'email de la boite
#   archive - deplace l'email dans le dossier IMAP_ARCHIVE_FOLDER
IMAP_PROCESSED_ACTION=delete

# Dossier de destination quand IMAP_PROCESSED_ACTION=archive
IMAP_ARCHIVE_FOLDER=Archive

# ─── Interface ───────────────────────────────────────────────────────────────
# Titre affiche dans l'onglet du navigateur
NEXT_PUBLIC_APP_TITLE=Dashorg

# ─── Stockage (optionnel - valeurs par defaut fournies) ──────────────────────
# Chemin absolu vers le fichier SQLite.
# Par defaut : /app/data/dashorg.db (production) ou ./data/dashorg.db (dev)
# DB_PATH=/data/dashorg.db

# Repertoire racine des fichiers uploades (pieces jointes, images).
# Par defaut : /app/uploads (production) ou ./uploads (dev)
# UPLOADS_ROOT=/data/uploads
